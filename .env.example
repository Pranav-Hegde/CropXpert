# =========================================================================
# Crop Recommendation System - Environment Variables Template
# Copy this file to `.env` in the root (or specific folders) and fill in the values.
# =========================================================================

# -------------------------------------------------------------------------
# Node.js Express Backend Configuration (Crop/Backend)
# -------------------------------------------------------------------------
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/Crop
JWT_SECRET=yourSuperSecretKey123

# -------------------------------------------------------------------------
# React Frontend Configuration (Crop/Frontend/frontend)
# Note: CRA environment variables MUST start with REACT_APP_
# -------------------------------------------------------------------------
REACT_APP_BACKEND_API_URL=http://localhost:5000
REACT_APP_RECOMMEND_API_URL=http://localhost:5001
REACT_APP_CARBON_API_URL=http://localhost:5002
